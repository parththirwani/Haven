generator client {
  provider = "prisma-client"
  output   = ".././generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  avatar      String?
  keySalt     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socialLinks Json?

  vaultItems  VaultItem[]
  notes       Note[]
  links       Link[]
  resources   Resource[]
  passwords   Password[]
  attachments Attachment[]
  audits      AuditLog[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model VaultItem {
  id        String    @id @default(uuid())
  userId    String
  type      ItemType
  count     Int?

  titleEnc  String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])

  note      Note?
  link      Link?
  resource  Resource?
  password  Password?

  attachments  Attachment[]
  audits       AuditLog[]
  linksTo      ItemLink[] @relation("LinkSource")
  linkedFrom   ItemLink[] @relation("LinkTarget")

  @@index([userId])
  @@index([userId, type])
  @@index([userId, deletedAt])
  @@index([userId, type, deletedAt])
}

enum ItemType {
  NOTE
  LINK
  RESOURCE
  PASSWORD
}

model Note {
  id          String    @id @default(uuid())
  vaultItemId String    @unique
  userId      String

  titleEnc    String?
  contentEnc  String
  previewEnc  String?
  tagsEnc     String?

  isPinned    Boolean   @default(false)
  wordCount   Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vaultItem   VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isPinned])
}

model Link {
  id             String    @id @default(uuid())
  vaultItemId    String    @unique
  userId         String

  urlEnc         String
  descriptionEnc String?
  tagsEnc        String?

  faviconUrl     String?
  siteName       String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vaultItem      VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Resource {
  id            String       @id @default(uuid())
  vaultItemId   String       @unique
  userId        String

  titleEnc      String?
  contentEnc    String
  sourceUrlEnc  String?
  authorEnc     String?
  tagsEnc       String?

  resourceType  ResourceType @default(ARTICLE)
  publishedAt   DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  vaultItem     VaultItem    @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, resourceType])
}

enum ResourceType {
  ARTICLE
  PAPER
  BOOK
  VIDEO
  PODCAST
  OTHER
}

model Password {
  id               String    @id @default(uuid())
  vaultItemId      String    @unique
  userId           String

  usernameEnc      String
  passwordEnc      String
  urlEnc           String?
  notesEnc         String?
  totpSecretEnc    String?

  passwordStrength Int?
  lastUsedAt       DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vaultItem        VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, passwordStrength])
}

model Attachment {
  id          String    @id @default(uuid())
  vaultItemId String
  userId      String

  metadataEnc String
  filePath    String?
  fileHash    String?
  mimeType    String?
  sizeBytes   Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vaultItem   VaultItem  @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])
  audits      AuditLog[]

  @@index([vaultItemId])
  @@index([userId])
}

model ItemLink {
  id            String    @id @default(uuid())
  sourceId      String
  targetId      String
  annotationEnc String?

  createdAt     DateTime  @default(now())

  source        VaultItem @relation("LinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target        VaultItem @relation("LinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String
  vaultItemId  String?
  attachmentId String?

  action       AuditAction
  timestamp    DateTime    @default(now())
  details      Json?

  prevHash     String?
  hash         String

  user         User        @relation(fields: [userId], references: [id])
  vaultItem    VaultItem?  @relation(fields: [vaultItemId], references: [id])
  attachment   Attachment? @relation(fields: [attachmentId], references: [id])

  @@index([userId, timestamp(sort: Desc)])
  @@index([vaultItemId])
}

enum AuditAction {
  CREATE
  VIEW
  UPDATE
  DELETE
  ATTACH_FILE
  DOWNLOAD_FILE
  LINK_CREATED
  LINK_REMOVED
}